# URL pública canônica do site, SEM barra final.
# Produção: https://sentoseadvogados.com.br  (ou o domínio definitivo)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — envio do formulário de contato.
RESEND_API_KEY=
# Remetente verificado no Resend. Ex.: "Site Sento-Sé <contato@sentoseadvogados.com.br>"
CONTACT_FROM_EMAIL=
# Para onde as mensagens do formulário são enviadas.
CONTACT_TO_EMAIL=

# ------------------------------------------------------------------
# Painel dos advogados (área logada)
# ------------------------------------------------------------------
# Supabase — do projeto já conectado à Vercel (Project Settings > API).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de serviço — SOMENTE servidor (criação de usuários/admin). Nunca exponha.
SUPABASE_SERVICE_ROLE_KEY=

# DataJud (CNJ) — cadastro gratuito em https://datajud.cnj.jus.br (consulta processual).
DATAJUD_API_KEY=

# (Fase futura) Judit — monitoramento por OAB.
# JUDIT_API_KEY=
# JUDIT_WEBHOOK_SECRET=
